# Root .env.example — reviewers: copy this to `.env` in the two app folders.
# The backend reads `apps/api/.env`; the frontend currently has no runtime env.
#
# Detailed backend defaults also live at apps/api/.env.example

# ---------- Backend (apps/api/.env) ----------
DATABASE_URL=sqlite:///./dev.db
JWT_SECRET=change-me-in-prod-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=20
REFRESH_TOKEN_DAYS=7
CORS_ORIGINS=http://localhost:5173

# AI provider: "mock" (default, no API key needed) or "openai" (requires OPENAI_API_KEY)
PROVIDER=mock
# OPENAI_API_KEY=sk-...
